    {
      "id": "s-MK59QpmZ_H59hS96giw",
      "type": "text",
      "x": 953.515625,
      "y": 960.5234375,
      "width": 700.559326171875,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,

    {
      "id": "QWRJQYRdgaLkqwPWjFnda",
      "type": "text",
      "x": 871.0498046875,
      "y": 1132.3076171875,
      "width": 778.3392333984375,
      "height": 50,
      "angle": 0,
      "strokeColor": "#6741d9",
      "backgroundColor": "#d0bfff",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "solid",

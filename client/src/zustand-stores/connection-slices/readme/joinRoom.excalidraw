      "isDeleted": false,
      "boundElements": null,
      "updated": 1781848343487,
      "link": null,
      "locked": false,
      "text": "peer.todayTotalDuration = todayTotalDuration\npeer.addRoom(room);\nroom.addPeer(peer);\nawait connectedSocket.join(roomId);\n...\n\nbroadcast with EventNames.ROOM_PEER_JOINED,\n    {\n      peerId: peer.id,\n      todayTotalDuration: peer.todayTotalDuration\n    });\n\n\n\n",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "peer.todayTotalDuration = todayTotalDuration\npeer.addRoom(room);\nroom.addPeer(peer);\nawait connectedSocket.join(roomId);\n...\n\nbroadcast with EventNames.ROOM_PEER_JOINED,\n    {\n      peerId: peer.id,\n      todayTotalDuration: peer.todayTotalDuration\n    });\n\n\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
